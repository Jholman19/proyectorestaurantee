<Window x:Class="RestauranteApp.ClienteFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📝 Datos del Cliente"
        Height="480" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundLight}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" Padding="20,16" Margin="0">
            <TextBlock Text="🧑‍💼 Formulario de Cliente" Style="{StaticResource TitleText}" FontSize="22"/>
        </Border>

        <!-- Form Content -->
        <Border Grid.Row="1" Padding="20" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Nombre -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="👤 Nombre" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="NombreBox" 
                         Padding="8" Height="32" FontSize="13"
                         BorderBrush="#FFBDBDBD" BorderThickness="1"
                         VerticalContentAlignment="Center" Background="White" Foreground="Black"
                         Margin="0,0,0,12"/>

                <!-- Documento -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="🆔 Documento" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="DocumentoBox" 
                         Padding="8" Height="32" FontSize="13"
                         BorderBrush="#FFBDBDBD" BorderThickness="1"
                         VerticalContentAlignment="Center" Background="White" Foreground="Black"
                         Margin="0,0,0,12"/>

                <!-- Teléfono -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="☎️ Teléfono" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TelefonoBox" 
                         Padding="8" Height="32" FontSize="13"
                         BorderBrush="#FFBDBDBD" BorderThickness="1"
                         VerticalContentAlignment="Center" Background="White" Foreground="Black"
                         Margin="0,0,0,12"/>

                <!-- Activo -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="✅ Estado" Style="{StaticResource FormLabel}"/>
                <CheckBox Grid.Row="3" Grid.Column="1" x:Name="ActivoCheck" Content="Cliente Activo" IsChecked="True" 
                          Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,0,12"/>

                <!-- Suscripción Info -->
                <Border Grid.Row="4" Grid.ColumnSpan="2" Padding="16" CornerRadius="8" 
                        BorderThickness="2" BorderBrush="{StaticResource BorderColor}" 
                        Background="White" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="⭐ Información de Suscripción" FontWeight="Bold" 
                                   Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="SuscripcionInfoText" Text="(sin datos)" TextWrapping="Wrap" 
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderColor}" 
                BorderThickness="0,1,0,0" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="❌ Cancelar" Width="140" Style="{StaticResource ModernButton}" 
                        Click="Cancelar_Click" Background="{StaticResource BorderColor}"/>
                <Button Content="💾 Guardar" Width="140" Style="{StaticResource ModernButton}" 
                        Click="Guardar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>