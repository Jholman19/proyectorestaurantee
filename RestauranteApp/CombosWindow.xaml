<Window x:Class="RestauranteApp.CombosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🍝 Gestión de Combos"
        Height="580" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundLight}">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" Padding="20,16" Margin="0">
            <TextBlock Text="🍕 Gestión de Combos de Menú" Style="{StaticResource TitleText}" FontSize="22"/>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,1" Padding="16">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="📋 Cargar" Width="110" Style="{StaticResource ModernButton}" Click="Cargar_Click"/>
                    <Button Content="➕ Nuevo" Width="110" Style="{StaticResource ModernButton}" Click="Nuevo_Click"/>
                    <Button Content="✏️ Editar" Width="110" Style="{StaticResource ModernButton}" Click="Editar_Click"/>
                    <Button Content="🔄 Activar/Inactivar" Width="160" Style="{StaticResource ModernButton}" Click="ToggleActivo_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock Text="🔍 Buscar:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                    <TextBox x:Name="BuscarBox" Width="220" Style="{StaticResource ModernTextBox}" 
                             TextChanged="BuscarBox_TextChanged" Margin="0"/>
                    <CheckBox x:Name="SoloActivosCheck" Content="Solo activos" Margin="16,0,0,0"
                        VerticalAlignment="Center" Checked="Filtro_Checked" Unchecked="Filtro_Checked"
                        Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Data Grid -->
            <Border Grid.Column="0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4" Background="White">
                <DataGrid x:Name="CombosGrid"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    SelectionMode="Single"
                    MouseDoubleClick="CombosGrid_DoubleClick"
                    CanUserAddRows="False"
                    AlternatingRowBackground="#FFFAFAFA"
                    RowHeight="28">
                    
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ComboId}" Width="70"/>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                        <DataGridCheckBoxColumn Header="🌅 Des." Binding="{Binding Desayuno}" Width="70"/>
                        <DataGridCheckBoxColumn Header="☀️ Alm." Binding="{Binding Almuerzo}" Width="70"/>
                        <DataGridCheckBoxColumn Header="🌙 Cena" Binding="{Binding Cena}" Width="70"/>
                        <DataGridCheckBoxColumn Header="✅ Activo" Binding="{Binding Activo}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Form Panel -->
            <Border Grid.Column="2" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" 
                    CornerRadius="4" Padding="16" Background="White">
                <StackPanel>
                    <TextBlock Text="📝 Datos del Combo" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" 
                               Margin="0,0,0,12" FontSize="14"/>

                    <!-- Nombre -->
                    <TextBlock Text="Nombre" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="NombreBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                    <!-- Meals -->
                    <TextBlock Text="Incluye" Style="{StaticResource FormLabel}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Vertical" Margin="0,0,0,12">
                        <CheckBox x:Name="DesayunoCheck" Content="🌅 Desayuno" Margin="0,0,0,6" 
                                  Foreground="{StaticResource TextPrimary}"/>
                        <CheckBox x:Name="AlmuerzoCheck" Content="☀️ Almuerzo" Margin="0,0,0,6" 
                                  Foreground="{StaticResource TextPrimary}"/>
                        <CheckBox x:Name="CenaCheck" Content="🌙 Cena" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>

                    <!-- Active -->
                    <CheckBox x:Name="ActivoCheck" Content="✅ Combo Activo" IsChecked="True" 
                              Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>

                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                        <TextBlock Text="💡 Tip: Doble click en un combo para cargarlo aquí."
                            Opacity="0.7" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>