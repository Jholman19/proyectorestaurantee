<Window x:Class="RestauranteApp.ComboForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🍝 Nuevo Combo"
        Height="380" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundLight}"
        Loaded="Window_Loaded">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" Padding="20,16" Margin="0">
            <TextBlock Text="🍕 Formulario de Combo" Style="{StaticResource TitleText}" FontSize="22"/>
        </Border>

        <!-- Form Content -->
        <Border Grid.Row="1" Padding="20" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Nombre -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="📝 Nombre:" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="NombreBox" 
                         Padding="8" Height="32" FontSize="13" 
                         BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                         VerticalContentAlignment="Center" Background="White" Foreground="Black"
                         Margin="0,0,0,16"/>

                <!-- Incluye -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="⏰ Incluye:" VerticalAlignment="Top" Style="{StaticResource FormLabel}"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Margin="0,0,0,16">
                    <CheckBox x:Name="DesayunoCheck" Content="🌅 Desayuno" Margin="0,0,0,8" Foreground="{StaticResource TextPrimary}"/>
                    <CheckBox x:Name="AlmuerzoCheck" Content="☀️ Almuerzo" Margin="0,0,0,8" Foreground="{StaticResource TextPrimary}"/>
                    <CheckBox x:Name="CenaCheck" Content="🌙 Cena" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>

                <!-- Activo -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="✅ Estado:" VerticalAlignment="Center" Style="{StaticResource FormLabel}"/>
                <CheckBox Grid.Row="2" Grid.Column="1" x:Name="ActivoCheck" Content="Combo Activo" IsChecked="True" 
                          Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,0,16"/>

                <!-- Error Message -->
                <TextBlock Grid.Row="3" Grid.ColumnSpan="2" x:Name="ErrorText" Foreground="{StaticResource ErrorColor}" 
                           TextWrapping="Wrap" Margin="0,0,0,16"/>
            </Grid>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderColor}" 
                BorderThickness="0,1,0,0" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="❌ Cancelar" Width="140" Style="{StaticResource ModernButton}" 
                        Background="{StaticResource BorderColor}" Click="Cancelar_Click"/>
                <Button Content="💾 Guardar" Width="140" Style="{StaticResource ModernButton}" Click="Guardar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>