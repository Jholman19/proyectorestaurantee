<Window x:Class="RestauranteApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mi Restaurante - Sistema de Gestión"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundLight}">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Logo Header with Gradient -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBorder}" Margin="0,0,0,0" CornerRadius="0">
            <DockPanel>
                <!-- Logo y Títulos -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0">
                    <Ellipse Width="60" Height="60" Fill="White" Margin="0,0,16,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🍕 Mi Restaurante" Style="{StaticResource TitleText}" FontSize="26" Margin="0"/>
                        <TextBlock Text="Sistema de Gestión" Style="{StaticResource SubtitleText}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Marquillas en la derecha -->
                <StackPanel Orientation="Vertical" DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="Software: Mi Restaurante" Style="{StaticResource SubtitleText}" TextAlignment="Right" Margin="0,0,0,4"/>
                    <TextBlock Text="Restaurante: Mi Amigo el Pizzero" Style="{StaticResource SubtitleText}" TextAlignment="Right" Margin="0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Buttons Bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,1" Padding="16">
            <WrapPanel>
                <Button Content="📋 Cargar" Width="100" Style="{StaticResource ModernButton}" Click="Cargar_Click"/>
                <Button Content="➕ Nuevo" Width="100" Style="{StaticResource ModernButton}" Click="Nuevo_Click"/>
                <Button Content="✏️ Editar" Width="100" Style="{StaticResource ModernButton}" Click="Editar_Click"/>
                <Button Content="�️ Eliminar" Width="100" Style="{StaticResource ModernButton}" Click="Eliminar_Click"/>
                <Button Content="�🔄 Activar/Inactivar" Width="150" Style="{StaticResource ModernButton}" Click="ToggleActivo_Click"/>
                
                <Separator Width="16" Background="Transparent"/>

                <Button Content="🍝 Combos" Width="100" Style="{StaticResource ModernButton}" Click="Combos_Click"/>
                <Button Content="⭐ Suscripciones" Width="130" Style="{StaticResource ModernButton}" Click="Suscripciones_Click"/>
                <Button Content="📊 Reportes" Width="120" Style="{StaticResource ModernButton}" Click="Reportes_Click"/>

                <Separator Width="16" Background="Transparent"/>

                <TextBlock Text="Buscar:" VerticalAlignment="Center" Margin="8,0,6,0" Foreground="{StaticResource TextPrimary}"/>
                <TextBox x:Name="BuscarBox" Width="240" Height="32" TextChanged="BuscarBox_TextChanged" 
                         Padding="8" VerticalContentAlignment="Center" Margin="0,0,12,0"/>

                <CheckBox x:Name="SoloActivosCheck" Content="Solo activos" Margin="0,0,0,0"
                    VerticalAlignment="Center"
                    Checked="Filtro_Checked" Unchecked="Filtro_Checked"
                    IsChecked="True" Foreground="{StaticResource TextPrimary}"/>
            </WrapPanel>
        </Border>

        <!-- Stats Bar (opcional) -->
        <Border Grid.Row="2" Background="White" Padding="16" Margin="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊 Gestión de Clientes" Foreground="{StaticResource PrimaryColor}" 
                           FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                <Separator Width="16" Background="Transparent"/>
                <TextBlock x:Name="StatsText" Text="Cargando datos..." Foreground="{StaticResource TextSecondary}" 
                           FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Grid -->
        <DataGrid Grid.Row="3"
            x:Name="ClientesGrid"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            CanUserAddRows="False"
            SelectionMode="Single"
            MouseDoubleClick="ClientesGrid_DoubleClick"
            Margin="16,0,16,16"
            Background="White"
            AlternatingRowBackground="#FFFAFAFA"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            RowHeight="28"
            VerticalScrollBarVisibility="Auto">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ClienteId}" Width="70"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                <DataGridTextColumn Header="Documento" Binding="{Binding Documento}" Width="160"/>
                <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="160"/>
                <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Activo}" Width="90"/>
                <DataGridTextColumn Header="Combo" Binding="{Binding ComboNombre}" Width="220"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>