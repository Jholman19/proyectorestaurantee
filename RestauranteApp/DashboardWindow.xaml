<Window x:Class="RestauranteApp.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 Dashboard de Reportes - Mi Restaurante"
        Width="900" Height="750" WindowStartupLocation="CenterScreen"
        Background="#F5F5F5" Foreground="#333333">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Logo -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Margin="0,0,0,0">
            <StackPanel Margin="20">
                <!-- Logo -->
                <Image Source="Resources/Images/Logos/logo-restaurante.png" 
                       Height="120" Width="240" Margin="0,0,0,10"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                
                <!-- Títulos -->
                <TextBlock Text="📊 ESTADÍSTICAS DEL DÍA" 
                           FontSize="28" FontWeight="Bold" 
                           Foreground="#2C3E50" TextAlignment="Center"/>
                <TextBlock x:Name="FechaTextBlock" 
                           FontSize="14" Foreground="#7F8C8D" 
                           TextAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content with Scroll -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,0,20,0">
            <StackPanel>

                <!-- 1️⃣ DESAYUNO -->
                <Border Background="White" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,15,0,15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="☀️" FontSize="20" Margin="0,0,10,0"/>
                            <TextBlock Text="DESAYUNO" FontSize="16" FontWeight="Bold" Foreground="#E67E22"/>
                            <TextBlock Text="(7:00 - 9:30)" FontSize="12" Foreground="#7F8C8D" Margin="10,3,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock x:Name="DesayunoConsumoText" Text="24" FontSize="20" FontWeight="Bold" Foreground="#27AE60"/>
                            <TextBlock Text="/" FontSize="20" Foreground="#7F8C8D" Margin="5,0"/>
                            <TextBlock x:Name="DesayunoTotalText" Text="45" FontSize="20" FontWeight="Bold" Foreground="#34495E"/>
                            <TextBlock Text="consumieron" FontSize="12" Foreground="#7F8C8D" Margin="8,6,0,0"/>
                        </StackPanel>

                        <!-- Barra de progreso -->
                        <ProgressBar x:Name="DesayunoProgressBar" Height="15" Foreground="#27AE60" 
                                     Background="#ECF0F1" Margin="0,0,0,8" Value="53"/>
                        <TextBlock x:Name="DesayunoProgressText" Text="53% - 21 faltantes" 
                                   FontSize="11" Foreground="#7F8C8D"/>
                    </StackPanel>
                </Border>

                <!-- 2️⃣ ALMUERZO -->
                <Border Background="White" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="🌤️" FontSize="20" Margin="0,0,10,0"/>
                            <TextBlock Text="ALMUERZO" FontSize="16" FontWeight="Bold" Foreground="#3498DB"/>
                            <TextBlock Text="(11:00 - 16:00)" FontSize="12" Foreground="#7F8C8D" Margin="10,3,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock x:Name="AlmuerzoConsumoText" Text="18" FontSize="20" FontWeight="Bold" Foreground="#2980B9"/>
                            <TextBlock Text="/" FontSize="20" Foreground="#7F8C8D" Margin="5,0"/>
                            <TextBlock x:Name="AlmuerzoTotalText" Text="45" FontSize="20" FontWeight="Bold" Foreground="#34495E"/>
                            <TextBlock Text="consumieron" FontSize="12" Foreground="#7F8C8D" Margin="8,6,0,0"/>
                        </StackPanel>

                        <!-- Barra de progreso -->
                        <ProgressBar x:Name="AlmuerzoProgressBar" Height="15" Foreground="#3498DB" 
                                     Background="#ECF0F1" Margin="0,0,0,8" Value="40"/>
                        <TextBlock x:Name="AlmuerzoProgressText" Text="40% - 27 faltantes" 
                                   FontSize="11" Foreground="#7F8C8D"/>
                    </StackPanel>
                </Border>

                <!-- 3️⃣ CENA -->
                <Border Background="White" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="🌙" FontSize="20" Margin="0,0,10,0"/>
                            <TextBlock Text="CENA" FontSize="16" FontWeight="Bold" Foreground="#8E44AD"/>
                            <TextBlock Text="(18:00 - 21:00)" FontSize="12" Foreground="#7F8C8D" Margin="10,3,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock x:Name="CenaConsumoText" Text="0" FontSize="20" FontWeight="Bold" Foreground="#8E44AD"/>
                            <TextBlock Text="/" FontSize="20" Foreground="#7F8C8D" Margin="5,0"/>
                            <TextBlock x:Name="CenaTotalText" Text="45" FontSize="20" FontWeight="Bold" Foreground="#34495E"/>
                            <TextBlock Text="sin iniciar" FontSize="12" Foreground="#E74C3C" Margin="8,6,0,0" FontWeight="Bold"/>
                        </StackPanel>

                        <!-- Barra de progreso -->
                        <ProgressBar x:Name="CenaProgressBar" Height="15" Foreground="#8E44AD" 
                                     Background="#ECF0F1" Margin="0,0,0,8" Value="0"/>
                        <TextBlock x:Name="CenaProgressText" Text="0% - 45 en espera" 
                                   FontSize="11" Foreground="#7F8C8D"/>
                    </StackPanel>
                </Border>

                <!-- Separador -->
                <Separator Background="#E0E0E0" Margin="0,10,0,15"/>

                <!-- Resumen de Faltantes -->
                <Border Background="White" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="📍 FALTANTES HOY" FontSize="14" FontWeight="Bold" 
                                   Foreground="#E74C3C" Margin="0,0,0,10"/>
                        
                        <TextBlock x:Name="FaltantesDesayunoLabel" 
                                   Text="☀️ Desayuno (21 faltantes):" FontSize="11" FontWeight="Bold" 
                                   Foreground="#E67E22" Margin="0,0,0,3"/>
                        <TextBlock x:Name="FaltantesDesayunoList" 
                                   Text="Ana García, Carlos López, Elena Martínez, Francisco González..." 
                                   FontSize="10" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock x:Name="FaltantesAlmuerzoLabel" 
                                   Text="🌤️ Almuerzo (27 faltantes):" FontSize="11" FontWeight="Bold" 
                                   Foreground="#3498DB" Margin="0,0,0,3"/>
                        <TextBlock x:Name="FaltantesAlmuerzoList" 
                                   Text="Pedro García, Gabriela Rodríguez, Isabel Fernández, Jorge Martínez..." 
                                   FontSize="10" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock x:Name="FaltantasCenaLabel" 
                                   Text="🌙 Cena (45 en espera):" FontSize="11" FontWeight="Bold" 
                                   Foreground="#8E44AD" Margin="0,0,0,3"/>
                        <TextBlock x:Name="FaltantasCenaList" 
                                   Text="Aún no inicia el horario de cena" 
                                   FontSize="10" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,0,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer with Buttons -->
        <StackPanel Grid.Row="2" Background="White" Margin="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                <Button x:Name="ActualizarButton" Content="🔄 Actualizar" Padding="15,8" 
                        Background="#3498DB" Foreground="White" FontWeight="Bold" 
                        Click="Actualizar_Click" Cursor="Hand"/>
                <Button x:Name="CerrarButton" Content="Cerrar" Padding="15,8" 
                        Background="#95A5A6" Foreground="White" FontWeight="Bold" 
                        Click="Cerrar_Click" Cursor="Hand"/>
            </StackPanel>
            <TextBlock x:Name="UltimaActualizacionText" Text="Última actualización: Hace unos momentos" 
                       FontSize="10" Foreground="#7F8C8D" TextAlignment="Right"/>
        </StackPanel>
    </Grid>
</Window>
